<div class="w-full h-56 p-8 bg-neutral-100 rounded-bl-[70px]">
  <div class="w-full flex justify-around items-center">
    <h1 class="font-bold text-3xl text-neutral-700">Hello, <span class="italic">@<%= current_user.username %></span></h1>
    <div class="bg-violet-200 p-6 rounded-lg">
      <h2 class="uppercase text-sm font-semibold md:text-left text-center text-neutral-700">currently reading</h2>

    </div>
  </div>
</div>

<div class="w-full px-8 mt-12 flex justify-around items-start">
  <%= image_tag 'https://res.cloudinary.com/dd7pbokmj/image/upload/v1672462192/books_pvqvm0.webp', class: 'rounded-lg w-2/5' %>
  <div class="text ml-14">
    <h2 class="font-bold text-3xl text-neutral-700">Best Books of 2022</h2>
    <p class="text-base mt-4 leading-relaxed tracking-wide">Announcing the winners of the 1th Annual Booksie Choice Awards, the only major book awards decided by readers. Congratulations to the best books of the year!</p>

    <div class="mt-16">
      <%= link_to "See the Winners", books_path, class: 'btn-violet-solid'  %>
    </div>
  </div>
</div>
